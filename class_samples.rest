# @name getToken
POST https://login.microsoftonline.com/{{tenantId}}/oauth2/v2.0/token
Content-Type: application/x-www-form-urlencoded

client_id={{clientId}}&
scope=https%3A%2F%2Fgraph.microsoft.com%2F.default&
client_secret={{clientSecret}}& 
grant_type=client_credentials

###
@accessToken = {{getToken.response.body.access_token}}

# ============================================================
# SECTION 1: APPLICATIONS
# ============================================================
# Get-AppsUsingWindowsAzureAdApi
# Find service principal for Windows Azure Active Directory
# Permission: Application.Read.All | Directory.Read.All

###
# [Applications] Get Windows Azure AD service principal by appId
GET https://graph.microsoft.com/v1.0/servicePrincipals
    ?$filter=appId eq '00000002-0000-0000-c000-000000000000'
    &$select=id
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
# [Applications] Get OAuth2 permission grants for Windows AAD resource
# Replace {windowsAzureAdPrincipalId} with the id returned above
GET https://graph.microsoft.com/v1.0/oauth2PermissionGrants
    ?$filter=resourceId eq '{windowsAzureAdPrincipalId}'
    &$select=clientId
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
# [Applications] Get service principals by id list (up to 15 at a time)
# Replace {id1},{id2},... with actual IDs from the consent grant results
GET https://graph.microsoft.com/v1.0/servicePrincipals
    ?$filter=id in ('{id1}','{id2}','{id3}')
    &$select=id,appId,appOwnerOrganizationId,displayName
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
# [Applications] Get app registration with owners expanded
# Replace {appId} with the target application's appId
GET https://graph.microsoft.com/v1.0/applications
    ?$filter=appId eq '{appId}'
    &$select=id
    &$expand=owners($select=displayName,userPrincipalName)
Content-Type: application/json
Authorization: Bearer {{accessToken}}


# ============================================================
# SECTION 2: DRIVES
# ============================================================
# Large file upload requires a multi-step process:
# 1. Create an upload session
# 2. PUT file chunks using the uploadUrl from the session

###
# [Drives] Create an upload session for a large file
# Replace {driveId} and {fileName} with actual values
POST https://graph.microsoft.com/v1.0/drives/{driveId}/items/root:/{fileName}:/createUploadSession
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "item": {
    "name": "{fileName}"
  }
}

###
# [Drives] Upload a file chunk (PUT to the uploadUrl from session above)
# Replace {uploadUrl} with the URL from the createUploadSession response
# Content-Range header must specify byte range and total size
PUT {uploadUrl}
Content-Range: bytes 0-327679/1000000
Content-Type: application/octet-stream

< path/to/your/local/file.bin


