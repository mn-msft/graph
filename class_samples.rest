Authorization: Bearer {{accessToken}}


# ============================================================
# SECTION 4: MAIL
# ============================================================
# Permission: Mail.Read
# Replace {userId} with the user's UPN or object ID

###
# [Mail] 01 - Get top 5 messages for a user
GET https://graph.microsoft.com/v1.0/users/{userId}/messages
    ?$top=5
    &$select=id,subject,conversationId,parentFolderId,createdDateTime,from,isRead
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
# [Mail] 02 - Search messages by subject keyword
# Replace {searchString} with your search term (e.g., "Weekly digest: Office 365 changes")
GET https://graph.microsoft.com/v1.0/users/{userId}/messages
    ?$search="{searchString}"
    &$select=id,subject,conversationId,parentFolderId,createdDateTime,from,isRead
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
# [Mail] 03 - Get a mail folder by ID (used to resolve parentFolderId)
# Replace {mailFolderId} with the parentFolderId from a message
GET https://graph.microsoft.com/v1.0/users/{userId}/mailFolders/{mailFolderId}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
# [Mail] 04 - Get internet message headers for a specific message
# Replace {messageId} with the target message ID
GET https://graph.microsoft.com/v1.0/users/{userId}/messages/{messageId}
    ?$select=internetMessageHeaders
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
# [Mail] 05 - Send an email on behalf of a user
# Permission: Mail.Send
# Replace {userId} with the sender's UPN or object ID
POST https://graph.microsoft.com/v1.0/users/{userId}/sendMail
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "message": {
    "subject": "Hello MS Graph!",
    "body": {
      "contentType": "Text",
      "content": "This is a sample mail sent via MS Graph. How cool is this?"
    },
    "toRecipients": [
      {
        "emailAddress": {
          "address": "recipient@contoso.com"
        }
      }
    ]
  }
}

###
# [Mail] 06 - Get calendar view for a room/user (utilization report)
# Permission: Calendars.Read
# Replace {roomEmail} with the room mailbox address
GET https://graph.microsoft.com/v1.0/users/{roomEmail}/calendarView
    ?startDateTime=2020-06-25T00:00:00Z
    &endDateTime=2020-08-03T00:00:00Z
Content-Type: application/json
Authorization: Bearer {{accessToken}}


